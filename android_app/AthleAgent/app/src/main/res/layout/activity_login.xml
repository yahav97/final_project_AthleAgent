<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/login_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background_white_alice_blue"
    tools:context=".ui.auth.LoginActivity">

    <ScrollView
        android:id="@+id/login_layout_content"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">

        <androidx.appcompat.widget.LinearLayoutCompat
            android:id="@+id/login_form_container"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_horizontal"
            android:orientation="vertical"
            android:paddingBottom="@dimen/spacing_32">

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/login_IMG_logo"
                android:layout_width="@dimen/logo_size"
                android:layout_height="@dimen/logo_height"
                android:layout_marginTop="@dimen/spacing_68"
                app:cardCornerRadius="@dimen/logo_radius"
                app:cardElevation="8dp"
                app:strokeWidth="0dp">

                <androidx.appcompat.widget.AppCompatImageView
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:contentDescription="@string/my_image_description"
                    android:scaleType="centerCrop"
                    app:srcCompat="@drawable/logon" />
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/login_BTN_google"
                style="@style/Widget.Material3.Button.ElevatedButton"
                android:layout_width="@dimen/button_width"
                android:layout_height="@dimen/spacing_56"
                android:layout_marginTop="@dimen/spacing_68"
                android:fontFamily="@font/roboto_bold"
                android:text="@string/google_login"
                android:textColor="@color/text"
                android:textSize="@dimen/text_size_body"
                app:backgroundTint="@color/white"
                app:cornerRadius="16dp"
                app:elevation="2dp"
                app:icon="@drawable/google"
                app:iconGravity="textStart"
                app:iconPadding="@dimen/google_icon_padding"
                app:iconSize="@dimen/spacing_24"
                app:iconTint="@null"
                app:strokeColor="@color/bright_gray"
                app:strokeWidth="1dp" />

            <com.google.android.material.textview.MaterialTextView
                android:id="@+id/login_LBL_or"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_24"
                android:fontFamily="@font/roboto_bold"
                android:text="@string/Or"
                android:textColor="@color/lm_text_muted"
                android:textSize="@dimen/text_size_body" />

            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/login_TIL_username"
                style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
                android:layout_width="@dimen/button_width"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_24"
                app:boxCornerRadiusBottomEnd="16dp"
                app:boxCornerRadiusBottomStart="16dp"
                app:boxCornerRadiusTopEnd="16dp"
                app:boxCornerRadiusTopStart="16dp"
                app:boxStrokeColor="@color/brand_button_light_muted"
                app:boxStrokeWidth="1dp"
                app:hintTextColor="@color/brand_button_dark_muted"
                app:startIconDrawable="@android:drawable/ic_menu_myplaces"
                app:startIconTint="@color/brand_button_light_muted">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/login_ET_username"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/roboto_regular"
                    android:hint="@string/User_name_text"
                    android:inputType="textEmailAddress"
                    android:paddingVertical="16dp"
                    android:textColor="@color/text" />
            </com.google.android.material.textfield.TextInputLayout>

            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/login_TIL_password"
                style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
                android:layout_width="@dimen/button_width"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_12"
                app:boxCornerRadiusBottomEnd="16dp"
                app:boxCornerRadiusBottomStart="16dp"
                app:boxCornerRadiusTopEnd="16dp"
                app:boxCornerRadiusTopStart="16dp"
                app:boxStrokeColor="@color/brand_button_light_muted"
                app:boxStrokeWidth="1dp"
                app:hintTextColor="@color/brand_button_dark_muted"
                app:passwordToggleEnabled="true"
                app:startIconDrawable="@android:drawable/ic_lock_idle_lock"
                app:startIconTint="@color/brand_button_light_muted">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/login_ET_password"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/roboto_regular"
                    android:hint="@string/Password_text"
                    android:inputType="textPassword"
                    android:paddingVertical="16dp"
                    android:textColor="@color/text" />
            </com.google.android.material.textfield.TextInputLayout>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/login_BTN_login"
                android:layout_width="@dimen/button_width"
                android:layout_height="@dimen/spacing_56"
                android:layout_marginTop="@dimen/spacing_32"
                android:background="@drawable/btn_gradient"
                android:fontFamily="@font/roboto_bold"
                android:text="@string/login_account_text"
                android:textColor="@color/white"
                android:textSize="@dimen/login_text_size"
                app:backgroundTint="@null"
                app:cornerRadius="16dp"
                app:elevation="4dp" />

            <com.google.android.material.textview.MaterialTextView
                android:id="@+id/login_LBL_forgotPassword"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_12"
                android:clickable="true"
                android:fontFamily="@font/roboto_bold"
                android:minHeight="@dimen/spacing_48"
                android:text="@string/forgotten_password"
                android:textColor="@color/brand_button_dark_muted"
                android:textSize="@dimen/text_size_body" />

            <androidx.appcompat.widget.LinearLayoutCompat
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_48"
                android:orientation="horizontal">

                <com.google.android.material.textview.MaterialTextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/roboto_regular"
                    android:text="@string/New_to_AthleAgent_text"
                    android:textColor="@color/text"
                    android:textSize="@dimen/text_size_body" />

                <com.google.android.material.textview.MaterialTextView
                    android:id="@+id/login_LBL_createAccount"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="@dimen/spacing_8"
                    android:clickable="true"
                    android:focusable="true"
                    android:fontFamily="@font/roboto_bold"
                    android:text="@string/create_account_text"
                    android:textColor="@color/brand_button_dark_muted"
                    android:textSize="@dimen/text_size_body" />
            </androidx.appcompat.widget.LinearLayoutCompat>

        </androidx.appcompat.widget.LinearLayoutCompat>
    </ScrollView>

    <RelativeLayout
        android:id="@+id/login_layout_loading"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:visibility="gone">

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/main_IMG_center_logo"
            android:layout_width="@dimen/logo_size"
            android:layout_height="@dimen/logo_height"
            android:layout_centerInParent="true"
            app:cardCornerRadius="@dimen/logo_radius"
            app:cardElevation="@dimen/logo_shadow"
            app:strokeWidth="0dp">

            <androidx.appcompat.widget.AppCompatImageView
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scaleType="centerCrop"
                app:srcCompat="@drawable/logon" />
        </com.google.android.material.card.MaterialCardView>

        <ProgressBar
            android:id="@+id/main_PRG_loading"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_below="@id/main_IMG_center_logo"
            android:layout_centerHorizontal="true"
            android:layout_marginTop="@dimen/spacing_32"
            android:indeterminateTint="@color/text" />

        <com.google.android.material.textview.MaterialTextView
            android:id="@+id/main_LBL_loading"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_below="@id/main_PRG_loading"
            android:layout_centerHorizontal="true"
            android:layout_marginTop="@dimen/spacing_16"
            android:fontFamily="@font/roboto_bold"
            android:text="@string/loading_dashboard"
            android:textColor="@color/text"
            android:textSize="@dimen/text_size_body" />
    </RelativeLayout>

</RelativeLayout>