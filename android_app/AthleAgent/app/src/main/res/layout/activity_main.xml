<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background_white_ghost"
    android:padding="@dimen/spacing_16"
    tools:context=".MainActivity">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_above="@id/footer_layout"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingBottom="@dimen/spacing_16">

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/imageView"
                android:layout_width="@dimen/logo_size"
                android:layout_height="@dimen/logo_height"
                android:layout_gravity="center_horizontal"
                android:layout_marginTop="@dimen/spacing_68"
                app:cardCornerRadius="@dimen/logo_radius"
                app:cardElevation="@dimen/logo_shadow"
                app:strokeWidth="0dp">

                <androidx.appcompat.widget.AppCompatImageView
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:contentDescription="@string/my_image_description"
                    android:scaleType="centerCrop"
                    app:srcCompat="@drawable/logon" />
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/GoogleSignInButton"
                android:layout_width="@dimen/button_width"
                android:layout_height="@dimen/spacing_56"
                android:layout_gravity="center_horizontal"
                android:layout_marginTop="@dimen/spacing_132"
                android:fontFamily="@font/roboto_bold"
                android:text="@string/google_login"
                android:textColor="@color/lm_text_secondary"
                android:textSize="@dimen/login_text_size"
                app:backgroundTint="@color/background_white_ghost"
                app:cornerRadius="@dimen/button_corner_radius"
                app:icon="@drawable/google"
                app:iconGravity="textStart"
                app:iconPadding="@dimen/google_icon_padding"
                app:iconSize="@dimen/spacing_24"
                app:iconTint="@null"
                app:strokeColor="@color/text_color_primary"
                app:strokeWidth="1dp" />

            <com.google.android.material.textview.MaterialTextView
                android:id="@+id/or"
                android:layout_width="@dimen/text_max_width"
                android:layout_height="@dimen/min_height"
                android:layout_gravity="center_horizontal"
                android:layout_marginTop="@dimen/spacing_12"
                android:clickable="true"
                android:fontFamily="@font/roboto_bold"
                android:gravity="center"
                android:text="@string/Or"
                android:textColor="@color/lm_text_secondary"
                android:textSize="@dimen/login_text_size" />

            <com.google.android.material.textfield.TextInputLayout
                style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
                android:layout_width="@dimen/text_max_width"
                android:layout_height="wrap_content"
                android:layout_gravity="center_horizontal"
                android:layout_marginTop="@dimen/spacing_16"
                app:boxCornerRadiusBottomEnd="@dimen/text_input_corner_radius"
                app:boxCornerRadiusBottomStart="@dimen/text_input_corner_radius"
                app:boxCornerRadiusTopEnd="@dimen/text_input_corner_radius"
                app:boxCornerRadiusTopStart="@dimen/text_input_corner_radius"
                app:boxStrokeColor="@color/text_color_primary"
                app:boxStrokeWidth="1dp"
                app:hintTextColor="@color/text_color_primary">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/editTextUsername"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:autofillHints="username"
                    android:fontFamily="@font/roboto_bold"
                    android:hint="@string/User_name_text"
                    android:inputType="textEmailAddress" />
            </com.google.android.material.textfield.TextInputLayout>

            <com.google.android.material.textfield.TextInputLayout
                style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
                android:layout_width="@dimen/text_max_width"
                android:layout_height="wrap_content"
                android:layout_gravity="center_horizontal"
                android:layout_marginTop="@dimen/spacing_12"
                app:boxCornerRadiusBottomEnd="@dimen/text_input_corner_radius"
                app:boxCornerRadiusBottomStart="@dimen/text_input_corner_radius"
                app:boxCornerRadiusTopEnd="@dimen/text_input_corner_radius"
                app:boxCornerRadiusTopStart="@dimen/text_input_corner_radius"
                app:boxStrokeColor="@color/text_color_primary"
                app:boxStrokeWidth="1dp"
                app:hintTextColor="@color/text_color_primary"
                app:passwordToggleEnabled="true">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/editTextPassword"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:autofillHints="password"
                    android:fontFamily="@font/roboto_bold"
                    android:hint="@string/Password_text"
                    android:inputType="textPassword" />
            </com.google.android.material.textfield.TextInputLayout>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/loginButton"
                android:layout_width="@dimen/button_width"
                android:layout_height="@dimen/min_height"
                android:layout_gravity="center_horizontal"
                android:layout_marginTop="@dimen/spacing_20"
                android:background="@drawable/btn_gradient"
                android:fontFamily="@font/roboto_bold"
                android:text="@string/login_account_text"
                android:textColor="@color/background_gray_smoke"
                android:textSize="@dimen/login_text_size"
                app:backgroundTint="@null"
                app:cornerRadius="@dimen/button_corner_radius"
                app:strokeColor="@color/aa_button_primary_bg"
                app:strokeWidth="@dimen/button_stroke_width" />

            <com.google.android.material.textview.MaterialTextView
                android:id="@+id/forgotPassword"
                android:layout_width="wrap_content"
                android:layout_height="@dimen/min_height"
                android:layout_gravity="center_horizontal"
                android:layout_marginTop="@dimen/spacing_12"
                android:clickable="true"
                android:fontFamily="@font/roboto_bold"
                android:gravity="center"
                android:text="@string/forgotten_password"
                android:textColor="@color/brand_button_dark_muted"
                android:textSize="@dimen/text_size_body" />
        </LinearLayout>
    </ScrollView>

    <androidx.appcompat.widget.LinearLayoutCompat
        android:id="@+id/footer_layout"
        android:layout_width="wrap_content"
        android:layout_height="@dimen/min_height"
        android:layout_alignParentBottom="true"
        android:layout_centerHorizontal="true"
        android:layout_marginBottom="@dimen/spacing_44"
        android:orientation="horizontal">

        <com.google.android.material.textview.MaterialTextView
            android:id="@+id/newToAthlelabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="@font/roboto_regular"
            android:text="@string/New_to_AthleAgent_text"
            android:textColor="@color/charcoal_black"
            android:textSize="@dimen/text_size_body" />

        <com.google.android.material.textview.MaterialTextView
            android:id="@+id/newAccountLink"
            android:layout_width="match_parent"
            android:layout_height="@dimen/min_height"
            android:layout_marginStart="@dimen/new_button_space"
            android:clickable="true"
            android:focusable="true"
            android:fontFamily="@font/roboto_bold"
            android:text="@string/create_account_text"
            android:textColor="@color/brand_button_dark_muted"
            android:textSize="@dimen/text_size_body" />

    </androidx.appcompat.widget.LinearLayoutCompat>

</RelativeLayout>