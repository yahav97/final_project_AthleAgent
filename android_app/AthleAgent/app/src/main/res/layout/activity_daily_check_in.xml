<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background_white_alice_blue"
    android:fillViewport="true">

    <androidx.appcompat.widget.LinearLayoutCompat
        android:id="@+id/checkin_form_container"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="@dimen/spacing_24">

        <com.google.android.material.textview.MaterialTextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:text="@string/daily_check_in"
            android:textSize="28sp"
            android:fontFamily="@font/roboto_bold"
            android:textColor="@color/text"
            android:layout_marginTop="16dp"
            android:layout_marginBottom="32dp"/>

        <!-- Energy Level Card -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="20dp"
            app:cardBackgroundColor="@color/white"
            app:cardCornerRadius="24dp"
            app:cardElevation="6dp"
            app:strokeWidth="0dp">

            <androidx.appcompat.widget.LinearLayoutCompat
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <com.google.android.material.textview.MaterialTextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/how_is_your_energy_level_today"
                    android:textSize="18sp"
                    android:textColor="@color/text"
                    android:fontFamily="@font/roboto_bold"
                    android:layout_marginBottom="16dp"/>

                <com.google.android.material.slider.Slider
                    android:id="@+id/checkin_SLD_energy"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:value="60"
                    android:valueFrom="0"
                    android:valueTo="100"
                    app:thumbColor="@color/brand_button_dark_muted"
                    app:trackColorActive="@color/brand_button_light_muted"
                    app:trackColorInactive="@color/background_dash" />

                <androidx.appcompat.widget.LinearLayoutCompat
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center"
                    android:layout_marginTop="8dp">

                    <com.google.android.material.textview.MaterialTextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="@string/emoji_very_sad"
                        android:textSize="24sp"
                        android:gravity="center"/>

                    <com.google.android.material.textview.MaterialTextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="@string/emoji_sad"
                        android:textSize="24sp"
                        android:gravity="center"/>

                    <com.google.android.material.textview.MaterialTextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="@string/emoji_neutral"
                        android:textSize="24sp"
                        android:gravity="center"/>

                    <com.google.android.material.textview.MaterialTextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="@string/emoji_happy"
                        android:textSize="24sp"
                        android:gravity="center"/>

                    <com.google.android.material.textview.MaterialTextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="@string/emoji_very_happy"
                        android:textSize="24sp"
                        android:gravity="center"/>
                </androidx.appcompat.widget.LinearLayoutCompat>
            </androidx.appcompat.widget.LinearLayoutCompat>
        </com.google.android.material.card.MaterialCardView>

        <!-- Muscle Soreness Card -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="20dp"
            app:cardBackgroundColor="@color/white"
            app:cardCornerRadius="24dp"
            app:cardElevation="6dp"
            app:strokeWidth="0dp">

            <androidx.appcompat.widget.LinearLayoutCompat
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <com.google.android.material.textview.MaterialTextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/daily_check_in_muscle"
                    android:textSize="18sp"
                    android:textColor="@color/text"
                    android:fontFamily="@font/roboto_bold"
                    android:layout_marginBottom="20dp"/>

                <androidx.appcompat.widget.LinearLayoutCompat
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <com.google.android.material.button.MaterialButton
                        style="@style/Widget.Material3.Button.OutlinedButton"
                        android:id="@+id/checkin_BTN_1"
                        android:layout_width="0dp"
                        android:layout_height="56dp"
                        android:layout_weight="1"
                        android:layout_marginEnd="4dp"
                        android:text="@string/number_1"
                        android:fontFamily="@font/roboto_bold"
                        android:textColor="@color/brand_button_dark_muted"
                        app:strokeColor="@color/brand_button_light_muted"
                        app:cornerRadius="12dp"
                        />

                    <com.google.android.material.button.MaterialButton
                        style="@style/Widget.Material3.Button.OutlinedButton"
                        android:id="@+id/checkin_BTN_2"
                        android:layout_width="0dp"
                        android:layout_height="56dp"
                        android:layout_weight="1"
                        android:layout_marginEnd="4dp"
                        android:text="@string/number_2"
                        android:fontFamily="@font/roboto_bold"
                        android:textColor="@color/brand_button_dark_muted"
                        app:strokeColor="@color/brand_button_light_muted"
                        app:cornerRadius="12dp"
                        />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/checkin_BTN_3"
                        android:layout_width="0dp"
                        android:layout_height="56dp"
                        android:layout_weight="1"
                        android:layout_marginEnd="4dp"
                        android:text="@string/number_3"
                        android:fontFamily="@font/roboto_bold"
                        android:textColor="@color/white"
                        android:background="@drawable/btn_gradient"
                        app:backgroundTint="@null"
                        app:cornerRadius="12dp"
                        />

                    <com.google.android.material.button.MaterialButton
                        style="@style/Widget.Material3.Button.OutlinedButton"
                        android:id="@+id/checkin_BTN_4"
                        android:layout_width="0dp"
                        android:layout_height="56dp"
                        android:layout_weight="1"
                        android:layout_marginEnd="4dp"
                        android:text="@string/number_4"
                        android:fontFamily="@font/roboto_bold"
                        android:textColor="@color/brand_button_dark_muted"
                        app:strokeColor="@color/brand_button_light_muted"
                        app:cornerRadius="12dp"
                        />

                    <com.google.android.material.button.MaterialButton
                        style="@style/Widget.Material3.Button.OutlinedButton"
                        android:id="@+id/checkin_BTN_5"
                        android:layout_width="0dp"
                        android:layout_height="56dp"
                        android:layout_weight="1"
                        android:text="@string/number_5"
                        android:fontFamily="@font/roboto_bold"
                        android:textColor="@color/brand_button_dark_muted"
                        app:strokeColor="@color/brand_button_light_muted"
                        app:cornerRadius="12dp"
                        />
                </androidx.appcompat.widget.LinearLayoutCompat>
            </androidx.appcompat.widget.LinearLayoutCompat>
        </com.google.android.material.card.MaterialCardView>

        <!-- Stress & Injury Card -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="32dp"
            app:cardBackgroundColor="@color/white"
            app:cardCornerRadius="24dp"
            app:cardElevation="6dp"
            app:strokeWidth="0dp">

            <androidx.appcompat.widget.LinearLayoutCompat
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <com.google.android.material.textview.MaterialTextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/stress_level_question"
                    android:textSize="18sp"
                    android:textColor="@color/text"
                    android:fontFamily="@font/roboto_bold"
                    android:layout_marginBottom="16dp"/>

                <com.google.android.material.slider.Slider
                    android:id="@+id/checkin_SLD_stress"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:value="30"
                    android:valueFrom="0"
                    android:valueTo="100"
                    app:thumbColor="@color/brand_button_dark_muted"
                    app:trackColorActive="@color/brand_button_light_muted"
                    app:trackColorInactive="@color/background_dash" />

                <androidx.appcompat.widget.LinearLayoutCompat
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="24dp">

                    <com.google.android.material.textview.MaterialTextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/low"
                        android:textSize="12sp"
                        android:textColor="@color/lm_text_muted"/>

                    <View
                        android:layout_width="0dp"
                        android:layout_height="1dp"
                        android:layout_weight="1"/>

                    <com.google.android.material.textview.MaterialTextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/high"
                        android:textSize="12sp"
                        android:textColor="@color/lm_text_muted"/>
                </androidx.appcompat.widget.LinearLayoutCompat>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="@color/bright_gray"
                    android:layout_marginBottom="20dp"/>

                <androidx.appcompat.widget.LinearLayoutCompat
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingVertical="4dp">

                    <com.google.android.material.textview.MaterialTextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="@string/injured_yesterday"
                        android:textSize="18sp"
                        android:textColor="@color/text"
                        android:fontFamily="@font/roboto_bold" />

                    <com.google.android.material.materialswitch.MaterialSwitch
                        android:id="@+id/checkin_SWITCH_injured"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginEnd="4dp"
                        app:thumbTint="@drawable/switch_thumb_selector"
                        app:trackTint="@drawable/switch_track_selector"
                        app:trackDecorationTint="@null" />

                </androidx.appcompat.widget.LinearLayoutCompat>
            </androidx.appcompat.widget.LinearLayoutCompat>
        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/dailyCheckIn_BTN_submit"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:layout_gravity="center"
            android:text="@string/submit"
            android:textAllCaps="false"
            android:background="@drawable/btn_gradient"
            android:fontFamily="@font/roboto_bold"
            android:textColor="@color/white"
            android:textSize="18sp"
            app:backgroundTint="@null"
            app:cornerRadius="16dp"
            app:elevation="4dp"
            />

    </androidx.appcompat.widget.LinearLayoutCompat>
</ScrollView>