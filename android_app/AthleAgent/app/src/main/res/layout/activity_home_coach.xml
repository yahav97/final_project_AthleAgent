<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background_white_alice_blue">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:fillViewport="true"
        app:layout_constraintBottom_toTopOf="@+id/btn_logout"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <androidx.appcompat.widget.LinearLayoutCompat
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="@dimen/spacing_24">

            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="@dimen/spacing_24">

                <androidx.appcompat.widget.LinearLayoutCompat
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_alignParentStart="true"
                    android:layout_toStartOf="@+id/coachHome_LBL_teamName"
                    android:orientation="vertical">

                    <com.google.android.material.textview.MaterialTextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/roboto_regular"
                        android:text="@string/welcome_coach"
                        android:textColor="@color/text"
                        android:textSize="@dimen/text_size_input_bigger" />

                    <com.google.android.material.textview.MaterialTextView
                        android:id="@+id/coachHome_LBL_name"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/roboto_bold"
                        android:text="@string/coach_name"
                        android:textColor="@color/brand_button_light_muted"
                        android:textSize="@dimen/headline_text_survey" />
                </androidx.appcompat.widget.LinearLayoutCompat>

                <com.google.android.material.textview.MaterialTextView
                    android:id="@+id/coachHome_LBL_teamName"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_alignParentEnd="true"
                    android:layout_centerVertical="true"
                    android:background="@drawable/bg_team_chip"
                    android:fontFamily="@font/roboto_bold"
                    android:paddingHorizontal="@dimen/spacing_16"
                    android:paddingVertical="@dimen/spacing_8"
                    android:text="@string/Team_name"
                    android:textColor="@color/brand_button_light_muted"
                    android:textSize="@dimen/text_size_input_bigger" />

            </RelativeLayout>

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/coachHome_CARD_notifications"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="@dimen/spacing_72"
                app:cardBackgroundColor="@color/background_white_floral"
                app:cardCornerRadius="@dimen/spacing_12"
                app:cardElevation="0dp"
                app:strokeColor="@color/fui_bgTwitter"
                app:strokeWidth="1.5dp">

                <androidx.appcompat.widget.LinearLayoutCompat
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:padding="@dimen/spacing_16">

                    <androidx.appcompat.widget.AppCompatImageView
                        android:layout_width="@dimen/spacing_36"
                        android:layout_height="@dimen/spacing_36"
                        android:src="@android:drawable/ic_menu_info_details"
                        app:tint="@color/fui_bgTwitter" />

                    <com.google.android.material.textview.MaterialTextView
                        android:id="@+id/coachHome_LBL_notifText"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="@dimen/spacing_12"
                        android:fontFamily="@font/roboto_bold"
                        android:text="@string/you_have_2_new_athlete_join_requests"
                        android:textColor="@color/brand_button_dark_muted"
                        android:textSize="@dimen/text_size_body" />
                </androidx.appcompat.widget.LinearLayoutCompat>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.textview.MaterialTextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="@dimen/spacing_32"
                android:fontFamily="@font/roboto_bold"
                android:text="@string/daily_actions"
                android:textColor="@color/brand_button_dark_muted"
                android:textSize="@dimen/login_text_size" />

            <androidx.appcompat.widget.LinearLayoutCompat
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:baselineAligned="false"
                android:orientation="horizontal">

                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/coachHome_BTN_dashboard"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="@dimen/spacing_8"
                    android:layout_weight="1"
                    android:clickable="true"
                    android:focusable="true"
                    app:cardBackgroundColor="@color/white"
                    app:cardCornerRadius="@dimen/spacing_20"
                    app:cardElevation="3dp">

                    <androidx.appcompat.widget.LinearLayoutCompat
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center"
                        android:orientation="vertical"
                        android:padding="@dimen/spacing_24">

                        <androidx.appcompat.widget.AppCompatImageView
                            android:layout_width="@dimen/spacing_44"
                            android:layout_height="@dimen/spacing_44"
                            android:layout_marginBottom="@dimen/spacing_16"
                            android:src="@drawable/sharp_patient_list_24"
                            app:tint="@color/material_dynamic_tertiary50" />

                        <com.google.android.material.textview.MaterialTextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:fontFamily="@font/roboto_bold"
                            android:text="@string/team_ndashboard"
                            android:textAlignment="center"
                            android:textColor="@color/text"
                            android:textSize="@dimen/text_size_input_bigger" />
                    </androidx.appcompat.widget.LinearLayoutCompat>
                </com.google.android.material.card.MaterialCardView>

                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/coachHome_BTN_manageTeam"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    android:layout_weight="1"
                    android:clickable="true"
                    android:focusable="true"
                    app:cardBackgroundColor="@color/white"
                    app:cardCornerRadius="@dimen/spacing_20"
                    app:cardElevation="3dp">

                    <androidx.appcompat.widget.LinearLayoutCompat
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center"
                        android:orientation="vertical"
                        android:padding="@dimen/spacing_24">

                        <androidx.appcompat.widget.AppCompatImageView
                            android:layout_width="@dimen/spacing_44"
                            android:layout_height="@dimen/spacing_44"
                            android:layout_marginBottom="@dimen/spacing_16"
                            android:src="@android:drawable/ic_menu_manage"
                            app:tint="@color/text" />

                        <com.google.android.material.textview.MaterialTextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:fontFamily="@font/roboto_bold"
                            android:text="@string/manage_nteam"
                            android:textAlignment="center"
                            android:textColor="@color/text"
                            android:textSize="@dimen/text_size_input_bigger" />
                    </androidx.appcompat.widget.LinearLayoutCompat>
                </com.google.android.material.card.MaterialCardView>
            </androidx.appcompat.widget.LinearLayoutCompat>
        </androidx.appcompat.widget.LinearLayoutCompat>
    </ScrollView>

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btn_logout"
        style="@style/Widget.Material3.Button.TextButton"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="@dimen/spacing_16"
        android:fontFamily="@font/roboto_bold"
        android:text="@string/log_out_coach"
        android:textColor="@color/text"
        android:textSize="@dimen/login_text_size"
        app:iconTint="@color/text"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>