# AthleAgent backend configuration
# Copy to backend/.env and uncomment or adjust as needed.
# Settings are defined in backend/config.py (pydantic-settings).

# --- Feature flags ---
# ENABLE_TEST_PREDICT_ENDPOINT=false

# --- ML model ---
# MODEL_PATH=                          # empty = promoted.json → backend/injury_model.pkl
# ML_MIN_RECALL_HARD=0.80              # default from ML_model/policy_config.py
# ML_MIN_AUC_FOR_LIVE=0.68             # default from ML_model/policy_config.py
# ML_DEGRADED_AUC_OFFSET=0.02

# --- Risk bands (must match Android UI) ---
# RISK_HIGH_CUTOFF=0.70
# RISK_MEDIUM_CUTOFF=0.20

# --- History & prediction confidence ---
# HISTORY_LOOKBACK_DAYS=7
# HISTORY_CONFIDENCE_HIGH_MIN_DAYS=7
# HISTORY_CONFIDENCE_MEDIUM_MIN_DAYS=4
# CONFIDENCE_HISTORY_WEIGHT=0.6
# CONFIDENCE_QUALITY_WEIGHT=0.4
# CONFIDENCE_SCORE_HIGH=0.95
# CONFIDENCE_SCORE_MEDIUM=0.70
# CONFIDENCE_SCORE_LOW=0.45

# --- Nutrition imputation defaults ---
# NUTRITION_DEFAULT_PROTEIN=130
# NUTRITION_DEFAULT_CARBS=300
# NUTRITION_DEFAULT_MEALS_LOGGED=3
# NUTRITION_DEFAULT_CALORIES=2600

# --- Firebase ---
# FIREBASE_SERVICE_ACCOUNT_KEY=backend/firebase-key.json
# GOOGLE_APPLICATION_CREDENTIALS=

# --- API server (local uvicorn) ---
# HOST=0.0.0.0
# PORT=8000
# CORS_ORIGINS=http://localhost:3000,http://localhost:8080,http://localhost:8000

# --- Logging ---
# LOG_DIR=logs
# LOG_LEVEL=INFO
# LOG_FORMAT=json
# LOG_MAX_BYTES=10000000
# LOG_BACKUP_COUNT=5

# --- HTTP middleware ---
# SLOW_REQUEST_MS=2000

# --- Client telemetry rate limits (seconds; 0 = no limit for that type) ---
# CLIENT_EVENT_RATE_LIMIT_SCREEN_SEC=30
# CLIENT_EVENT_RATE_LIMIT_ACTION_SEC=10
# CLIENT_EVENT_RATE_LIMIT_SYNC_SEC=15
# CLIENT_EVENT_RATE_LIMIT_ML_TRIGGER_SEC=5
# CLIENT_EVENT_MAX_TRACKED_KEYS=10000
# CLIENT_EVENT_STALE_ENTRY_SECONDS=86400

# --- Dev mock endpoint (when ENABLE_TEST_PREDICT_ENDPOINT=true) ---
# TEST_PREDICT_MOCK_RISK_PERCENTAGE=72.5
